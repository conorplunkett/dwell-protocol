{
  "manifest_version": 3,
  "name": "Dwell Protocol — Earn from ChatGPT, Claude & Gemini",
  "version": "0.8.1",
  "description": "Earn dwells while you use AI. One sponsored line appears while AI thinks; earnings are yours to redeem.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "DWELL — earnings",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://wpjfhezklpczxzocgxsb.supabase.co/*",
    "https://dwellprotocol.com/*",
    "https://www.dwellprotocol.com/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "src/ads.js",
        "src/content.js"
      ],
      "css": [
        "src/inject.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://dwellprotocol.com/*",
        "https://www.dwellprotocol.com/*"
      ],
      "js": [
        "src/link.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/tokens/*.png"
      ],
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ]
    }
  ]
}
